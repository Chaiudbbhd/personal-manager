{
  "appId": "com.lpk.notionmanager",
  "productName": "LPK Notion Manager",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "main.js",
    "preload.js",
    "database/**/*",
    "package.json"
  ],
  "mac": {
    "target": "dmg",
    "category": "public.app-category.productivity"
  },
  "win": {
    "target": "nsis"
  },
  "linux": {
    "target": "AppImage"
  }
}
